# Copy this file into the GitHub Actions secret named EC2_ENV_FILE.
# Do not commit real values.

JWT_SECRET=replace_with_a_long_random_secret
GEMINI_API_KEY=your_gemini_api_key

# Docker database settings for the db service in docker-compose.yml
DB_USER=postgres
DB_PASSWORD=replace_with_a_strong_password
DB_NAME=viba_db

# Optional Cloudflare R2 settings
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=
